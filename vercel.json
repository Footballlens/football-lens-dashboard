{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "functions": {
    "api/cron.js":       { "memory": 512, "maxDuration": 60 },
    "api/live.js":       { "memory": 256, "maxDuration": 30 },
    "api/engagement.js": { "memory": 256, "maxDuration": 60 },
    "api/fixtures.js":   { "memory": 256, "maxDuration": 30 },
    "api/standings.js":  { "memory": 256, "maxDuration": 30 },
    "api/generate.js":   { "memory": 256, "maxDuration": 30 },
